{
  "name": "crewdock",
  "version": "0.1.1",
  "private": true,
  "license": "MIT",
  "description": "Desktop workspace switcher with PTY-backed terminals and built-in source control",
  "type": "module",
  "scripts": {
    "postinstall": "npm run sync:xterm",
    "sync:xterm": "node scripts/sync-xterm-assets.mjs",
    "dev": "bash scripts/run-dev.sh",
    "dev:mac": "bash scripts/run-macos-dev-app.sh",
    "dev:tauri": "cargo tauri dev",
    "dev:bin": "cargo run --manifest-path src-tauri/Cargo.toml",
    "dev:build-app": "bash scripts/run-macos-dev-app.sh --build-only",
    "build:tauri": "cargo tauri build",
    "build:mac": "bash scripts/build-macos-dmg.sh",
    "build:windows:nsis": "cargo tauri build --target x86_64-pc-windows-msvc",
    "build:windows:nsis:xwin": "cargo tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml",
    "fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --all"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "mermaid": "^11.14.0"
  }
}
