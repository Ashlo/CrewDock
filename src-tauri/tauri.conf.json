{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CrewDock",
  "version": "0.1.1",
  "identifier": "com.ashlab.crewdock",
  "build": {
    "frontendDist": "../src-web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "CrewDock",
        "width": 1480,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 780,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self' tauri: asset: http://tauri.localhost; connect-src ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; img-src 'self' data: asset:; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true
  }
}
